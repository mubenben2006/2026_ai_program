   "cell_type": "code",
   "source": [
    "#Z-score标准化\n",
    "def z_score_norm(x):\n",
    "    mean=x.mean(axis=0,keepdims=True)\n",
    "    std=x.std(axis=0,keepdims=True)\n",
    "    std[std==0]=1.0  #避免除0\n",
    "    return (x-mean)/std\n",
    "\n",
    "#One-hot编码\n",
    "def one_hot(labels,num_classes):\n",
    "    return np.eye(num_classes)[labels]\n",
    "\n",
    "#Softmax\n",
    "def softmax(x):\n",
    "    exp_x=np.exp(x-np.max(x,axis=-1,keepdims=True)) #防溢出\n",
    "    return exp_x/np.sum(exp_x,axis=-1,keepdims=True)\n",
    "\n",
    "#L2归一化\n",
    "def l2_normalize(x,axis=-1,eps=1e-8):\n",
    "    norm=np.linalg.norm(x,axis=axis,keepdims=True)\n",
    "    return x/(norm + eps)\n",
    "\n",
    "#余弦相似度\n",
    "def cos_similarity(x,y):\n",
    "    x_norm=l2_normalize(x)\n",
    "    y_norm=l2_normalize(y)\n",
    "    similarity=x_norm@y_norm\n",
    "    return similarity\n",
    "\n",
    "#Top_k检索\n",
    "def Top_K(X,q):\n",
    "    X=l2_normalize(X)\n",
    "    q=l2_normalize(q)\n",
    "    similarity=cos_similarity(X,q)\n",
    "\n",
    "    top_k_index=np.argsort(similarity)[::-1][:5]\n",
    "    top_k_score=similarity[top_k_index]\n",
    "    return top_k_index,top_k_score"
   ],
   "id": "9516a07758d58c9a",
