    "# 输出\n",
    "q=np.random.randn(D)\n",
    "top_k_index,top_k_score=Top_K(X,q)\n",
    "\n",
    "print(\"\\nTop-5 最相似样本 (index, score):\")\n",
    "for index,score in zip(top_k_index, top_k_score):\n",
    "    print(f\"index: {index:3d}, score: {score:.4f}\")"
   ],
